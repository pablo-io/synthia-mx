---
// ─── Contenido de la sección "Soluciones de IA" ──────────────────────
// Edita estos valores para actualizar el texto sin tocar el HTML.
const content = {
  eyebrow: 'Soluciones de',
  title:   'Inteligencia Artificial',
  body: [
    'Synthia IA es una empresa de Inteligencia Artificial premiada y reconocida internacionalmente por sus diversas soluciones de negocio en los campos de Visión Computacional (CV) y Procesamiento del Lenguaje Natural (NLP).',
    'Nos especializamos en ayudar a las empresas a alcanzar la excelencia operativa y materializar sus ideas o proyectos a través de Inteligencia Artificial con soluciones hechas a la medida de sus necesidades.',
  ],
  cta: { label: 'Contacto', href: '#contacto' },
  robotImage: 'https://placehold.co/400x450/226AF8/ffffff?text=Synthia+Robot',
};
---

<section id="about" class="relative overflow-hidden" aria-label="Soluciones de Inteligencia Artificial">

  <!-- Halo de luz azul lateral izquierdo -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse 60% 70% at 15% 50%, rgba(34,106,248,0.25) 0%, transparent 70%)"
  ></div>

  <div class="relative container-synthia py-24 md:py-32">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">

      <!-- Texto -->
      <div>
        <p class="text-synthia-blue text-sm font-semibold uppercase tracking-widest mb-3">
          {content.eyebrow}
        </p>
        <h2 class="text-4xl md:text-5xl font-extrabold text-white uppercase leading-tight mb-6">
          {content.title}
        </h2>
        {content.body.map(paragraph => (
          <p class="text-white/70 text-base md:text-lg leading-relaxed mb-4">
            {paragraph}
          </p>
        ))}
        <a href={content.cta.href} class="btn-blue mt-4 inline-flex">
          {content.cta.label} <span aria-hidden="true">→</span>
        </a>
      </div>

      <!-- Imagen robot mascota -->
      <div class="flex justify-center md:justify-end">
        <img
          src={content.robotImage}
          alt="Mascota robot Synthia IA"
          width="400"
          height="450"
          class="max-w-xs md:max-w-sm w-full object-contain drop-shadow-2xl"
          loading="lazy"
        />
      </div>

    </div>
  </div>

</section>
