---
// ─── Sección de Contacto ──────────────────────────────────────────────
// Edita los datos de contacto aquí.
const info = {
  telefono: '(55) 5941 4541',
  // Para activar envío real reemplaza el action con Formspree, Netlify Forms, etc.
  // Ej Formspree: 'https://formspree.io/f/TU_ID'
  formAction: '#',
};

const social = [
  { label: 'Facebook', href: 'https://facebook.com', icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-7 h-7"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878V14.89h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/></svg>` },
  { label: 'Twitter',  href: 'https://twitter.com',  icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-7 h-7"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>` },
  { label: 'YouTube',  href: 'https://youtube.com',  icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-7 h-7"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>` },
  { label: 'LinkedIn', href: 'https://linkedin.com', icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-7 h-7"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>` },
];
---

<section id="contacto" class="bg-synthia-navy py-20" aria-label="Contacto">

  <div class="container-synthia">

    <!-- Título -->
    <h2 class="text-4xl md:text-5xl font-extrabold text-white text-center uppercase mb-2">
      Contacto
    </h2>
    <span class="title-divider"></span>

    <!-- Card del formulario -->
    <div class="max-w-2xl mx-auto bg-white/10 backdrop-blur-sm rounded-2xl border border-white/20 p-8 md:p-12 mt-10">
      <form
        action={info.formAction}
        method="POST"
        class="flex flex-col gap-5"
        novalidate
      >
        <!-- Nombre -->
        <div>
          <label for="nombre" class="sr-only">Nombre</label>
          <input
            id="nombre"
            name="nombre"
            type="text"
            placeholder="Nombre"
            required
            class="w-full bg-white/10 border border-white/30 rounded-lg px-4 py-3 text-white
                   placeholder-blue-200 focus:outline-none focus:border-synthia-green
                   focus:ring-1 focus:ring-synthia-green transition"
          />
        </div>

        <!-- Email -->
        <div>
          <label for="email" class="sr-only">Email</label>
          <input
            id="email"
            name="email"
            type="email"
            placeholder="Email"
            required
            class="w-full bg-white/10 border border-white/30 rounded-lg px-4 py-3 text-white
                   placeholder-blue-200 focus:outline-none focus:border-synthia-green
                   focus:ring-1 focus:ring-synthia-green transition"
          />
        </div>

        <!-- Mensaje -->
        <div>
          <label for="mensaje" class="sr-only">Mensaje</label>
          <textarea
            id="mensaje"
            name="mensaje"
            placeholder="Mensaje"
            required
            rows="6"
            class="w-full bg-white/10 border border-white/30 rounded-lg px-4 py-3 text-white
                   placeholder-blue-200 focus:outline-none focus:border-synthia-green
                   focus:ring-1 focus:ring-synthia-green transition resize-none"
          ></textarea>
        </div>

        <!-- Botón enviar -->
        <button
          type="submit"
          class="btn-blue w-full justify-center text-base py-4"
        >
          Enviar <span aria-hidden="true">→</span>
        </button>
      </form>
    </div>

    <!-- Redes y teléfono -->
    <div class="mt-14 grid grid-cols-1 md:grid-cols-2 gap-10 max-w-2xl mx-auto text-center">

      <!-- Redes -->
      <div>
        <h3 class="text-white font-bold text-lg uppercase mb-4">Redes</h3>
        <div class="flex justify-center gap-5">
          {social.map(s => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={s.label}
              class="text-blue-200 hover:text-synthia-green transition-colors"
              set:html={s.icon}
            />
          ))}
        </div>
      </div>

      <!-- Hablemos -->
      <div>
        <h3 class="text-white font-bold text-lg uppercase mb-4">Hablemos</h3>
        <a
          href={`tel:${info.telefono.replace(/\D/g,'')}`}
          class="text-blue-200 text-xl font-semibold hover:text-synthia-green transition-colors"
        >
          {info.telefono}
        </a>
      </div>

    </div>

  </div>

</section>
