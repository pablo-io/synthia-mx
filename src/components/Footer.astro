---
// ─── Datos del Footer ────────────────────────────────────────────────
// Edita estos arrays para actualizar el contenido sin tocar el HTML.

const registros = [
  'DUNS 812915931',
  'CONACYT (RENIECYT)',
  'ISO 9001',
];

const contacto = {
  direccion: 'Río Danubio 80, CDMX',
  telefono: '(55) 5941 4541',
  href: '#contacto',
};

const nosotros = [
  { label: 'BADAK', href: '#' },
  { label: 'Política de privacidad', href: '#' },
  { label: 'Política de calidad', href: '#' },
];

const social = [
  {
    label: 'Facebook',
    href: 'https://facebook.com',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878V14.89h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/></svg>`,
  },
  {
    label: 'Twitter / X',
    href: 'https://twitter.com',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
  },
  {
    label: 'YouTube',
    href: 'https://youtube.com',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>`,
  },
  {
    label: 'LinkedIn',
    href: 'https://linkedin.com',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  },
];
---

<footer class="bg-synthia-navy-dark text-white">

  <!-- Forma decorativa superior (chevron) -->
  <div class="overflow-hidden leading-none" style="height:60px">
    <svg viewBox="0 0 1440 60" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" class="w-full h-full">
      <polygon points="0,60 720,0 1440,60" fill="#226AF8" />
    </svg>
  </div>

  <div class="container-synthia py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">

      <!-- Columna 1: Registros -->
      <div>
        <h3 class="text-lg font-bold uppercase mb-4 border-l-4 border-synthia-green pl-3">
          Registros
        </h3>
        <ul class="space-y-2">
          {registros.map(item => (
            <li class="flex items-center gap-2 text-sm text-blue-100">
              <span class="text-synthia-green font-bold">›</span>
              {item}
            </li>
          ))}
        </ul>
      </div>

      <!-- Columna 2: Contacto -->
      <div>
        <h3 class="text-lg font-bold uppercase mb-4 border-l-4 border-synthia-green pl-3">
          Contacto
        </h3>
        <ul class="space-y-2 text-sm text-blue-100">
          <li class="flex items-center gap-2">
            <span class="text-synthia-green font-bold">›</span>
            {contacto.direccion}
          </li>
          <li class="flex items-center gap-2">
            <span class="text-synthia-green font-bold">›</span>
            {contacto.telefono}
          </li>
          <li>
            <a
              href={contacto.href}
              class="flex items-center gap-2 hover:text-synthia-green transition-colors"
            >
              <span class="text-synthia-green font-bold">›</span>
              Contáctanos
            </a>
          </li>
        </ul>
      </div>

      <!-- Columna 3: Nosotros -->
      <div>
        <h3 class="text-lg font-bold uppercase mb-4 border-l-4 border-synthia-green pl-3">
          Nosotros
        </h3>
        <ul class="space-y-2">
          {nosotros.map(link => (
            <li>
              <a
                href={link.href}
                class="flex items-center gap-2 text-sm text-blue-100 hover:text-synthia-green transition-colors"
              >
                <span class="text-synthia-green font-bold">›</span>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

    </div>

    <!-- Redes sociales -->
    <div class="mt-10 flex justify-center gap-6">
      {social.map(s => (
        <a
          href={s.href}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={s.label}
          class="text-white hover:text-synthia-green transition-colors"
          set:html={s.icon}
        />
      ))}
    </div>

  </div>

  <!-- Barra inferior de copyright -->
  <div class="bg-synthia-blue py-3 text-center text-sm font-medium">
    2021 Copyrights Synthia Inteligencia Artificial México
  </div>

</footer>
