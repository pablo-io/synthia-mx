---
// Header minimalista flotante.
// Transparente en top, oscuro con blur al hacer scroll.
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="container-synthia flex items-center justify-between h-16">

    <!-- Logo -->
    <a href="/" class="flex items-center shrink-0">
      <img
        src="https://synthia.mx/wp-content/uploads/2021/04/LogoSynthia-01-1.png"
        alt="Synthia - Inteligencia Artificial"
        width="140"
        height="44"
        class="h-9 w-auto object-contain brightness-0 invert"
      />
    </a>

    <!-- Botón Contacto -->
    <a
      href="#contacto"
      class="text-sm font-semibold text-white bg-synthia-blue border border-synthia-blue px-5 py-2 rounded-full
             hover:bg-synthia-blue/80 hover:shadow-[0_0_16px_rgba(34,106,248,0.5)] transition-all duration-200"
    >
      Contacto
    </a>

  </div>
</header>

<script>
  const header = document.getElementById('header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      header?.classList.add('bg-synthia-navy-dark/90', 'backdrop-blur-md', 'shadow-lg');
    } else {
      header?.classList.remove('bg-synthia-navy-dark/90', 'backdrop-blur-md', 'shadow-lg');
    }
  }, { passive: true });
</script>
