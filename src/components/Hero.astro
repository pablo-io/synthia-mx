---
// ─── Slides del Hero ─────────────────────────────────────────────────
// Edita este array para cambiar títulos, subtítulos, imágenes y enlaces.
// Para imágenes reales reemplaza el campo `image` con la ruta en /public/
const slides = [
  {
    title: 'Monitor Inteligente de Choferes',
    subtitle: 'Conoce algunas de las soluciones que nuestros expertos han desarrollado para diversas industrias.',
    image: 'https://placehold.co/1440x700/072146/226AF8?text=Monitor+Inteligente',
    href: '#casos',
  },
  {
    title: 'Plataforma Biométrica',
    subtitle: 'Conoce algunas de las soluciones que nuestros expertos han desarrollado para diversas industrias.',
    image: 'https://placehold.co/1440x700/071F3B/226AF8?text=Plataforma+Biométrica',
    href: '#casos',
  },
  {
    title: 'Smart Street',
    subtitle: 'Conoce algunas de las soluciones que nuestros expertos han desarrollado para diversas industrias.',
    image: 'https://placehold.co/1440x700/0014B0/61CE70?text=Smart+Street',
    href: '#casos',
  },
  {
    title: 'Know Your Customer',
    subtitle: 'Conoce algunas de las soluciones que nuestros expertos han desarrollado para diversas industrias.',
    image: 'https://placehold.co/1440x700/072146/226AF8?text=Know+Your+Customer',
    href: '#casos',
  },
  {
    title: 'Visual Tracker',
    subtitle: 'Conoce algunas de las soluciones que nuestros expertos han desarrollado para diversas industrias.',
    image: 'https://placehold.co/1440x700/071F3B/61CE70?text=Visual+Tracker',
    href: '#casos',
  },
];
---

<section id="hero" class="relative overflow-hidden" aria-label="Hero">

  <!-- Carrusel -->
  <div id="hero-carousel" class="relative">

    <!-- Slides -->
    {slides.map((slide, i) => (
      <div
        class:list={[
          'hero-slide absolute inset-0 transition-opacity duration-700',
          i === 0 ? 'opacity-100 z-10' : 'opacity-0 z-0',
        ]}
        data-index={i}
        aria-hidden={i !== 0}
      >
        <!-- Imagen de fondo -->
        <img
          src={slide.image}
          alt=""
          class="absolute inset-0 w-full h-full object-cover"
          loading={i === 0 ? 'eager' : 'lazy'}
        />
        <!-- Overlay oscuro -->
        <div class="absolute inset-0 bg-synthia-navy/70"></div>

        <!-- Contenido centrado -->
        <div class="relative z-10 flex flex-col items-center justify-center text-center px-6 h-full">
          <h1 class="text-4xl md:text-6xl font-extrabold text-white uppercase leading-tight max-w-4xl">
            {slide.title}
          </h1>
          <!-- Divisor azul -->
          <span class="block w-40 h-1 bg-synthia-blue my-5"></span>
          <p class="text-white text-base md:text-lg max-w-xl mb-8">
            {slide.subtitle}
          </p>
          <a href={slide.href} class="btn-green">
            Conoce más <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    ))}

    <!-- Contenedor de altura (el slide absoluto no ocupa espacio) -->
    <div class="h-[85vh] min-h-[500px]"></div>
  </div>

  <!-- Puntos de navegación -->
  <div
    class="absolute bottom-6 left-1/2 -translate-x-1/2 z-20 flex gap-3"
    role="tablist"
    aria-label="Navegación de slides"
  >
    {slides.map((_, i) => (
      <button
        class:list={[
          'hero-dot w-3 h-3 rounded-full transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-synthia-green',
          i === 0 ? 'bg-synthia-blue scale-125' : 'bg-white/50',
        ]}
        data-dot={i}
        role="tab"
        aria-selected={i === 0}
        aria-label={`Slide ${i + 1}`}
      />
    ))}
  </div>

</section>

<script>
  // ─── Lógica del carrusel ───────────────────────────────────────────
  const slides = document.querySelectorAll<HTMLElement>('.hero-slide');
  const dots   = document.querySelectorAll<HTMLElement>('.hero-dot');
  let current  = 0;
  let timer: ReturnType<typeof setInterval>;

  function goTo(index: number) {
    // Ocultar slide actual
    slides[current].classList.remove('opacity-100', 'z-10');
    slides[current].classList.add('opacity-0', 'z-0');
    slides[current].setAttribute('aria-hidden', 'true');
    dots[current].classList.remove('bg-synthia-blue', 'scale-125');
    dots[current].classList.add('bg-white/50');

    // Mostrar nuevo slide
    current = (index + slides.length) % slides.length;
    slides[current].classList.remove('opacity-0', 'z-0');
    slides[current].classList.add('opacity-100', 'z-10');
    slides[current].setAttribute('aria-hidden', 'false');
    dots[current].classList.remove('bg-white/50');
    dots[current].classList.add('bg-synthia-blue', 'scale-125');
  }

  function startAutoplay() {
    timer = setInterval(() => goTo(current + 1), 5000);
  }

  function resetAutoplay() {
    clearInterval(timer);
    startAutoplay();
  }

  // Clicks en puntos
  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => { goTo(i); resetAutoplay(); });
  });

  // Arrancar autoplay
  startAutoplay();

  // Pausar si el usuario tiene preferencia de movimiento reducido
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    clearInterval(timer);
  }
</script>
